# Copy this file to .env.local (dev) or .env.production (build) and fill in your
# Firebase web app config. Find these in the Firebase console:
#   Project settings -> General -> Your apps -> SDK setup and configuration.
# These values are NOT secret - access is controlled by Firestore security rules.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Internal domain used to turn usernames into Firebase Auth emails.
# Must match GUILD_EMAIL_DOMAIN used by the seed script. Leave as-is unless you
# have a reason to change it.
VITE_GUILD_EMAIL_DOMAIN=nsanglers.local

# --- Optional: only if you use the self-hosted Node backend instead of Firebase ---
# VITE_API_URL=http://localhost:8787
