rules_version = '2';

// Nova Scotian Anglers Guild - Firestore security.
// Only active members can read the roster; only admins manage members; each
// member writes only their own live-presence doc.
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }
    function meDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function isActiveMember() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && meDoc().active == true;
    }
    function isAdmin() {
      return isActiveMember() && meDoc().role == 'admin';
    }

    match /users/{uid} {
      // Active members can see the roster; anyone signed in can read their OWN
      // profile (so a disabled account gets a clear message instead of an error).
      allow read: if isActiveMember() || (signedIn() && request.auth.uid == uid);
      // Only admins create/modify/remove member profiles.
      allow create, update, delete: if isAdmin();
    }

    match /presence/{uid} {
      // Active members can see where everyone sharing currently is.
      allow read: if isActiveMember();
      // You can only write (and clear) your OWN presence doc.
      allow write: if isActiveMember() && request.auth.uid == uid;
    }

    match /trips/{tripId} {
      // Admins can read every member's trips & notes; members read only their own.
      allow read: if isAdmin() || (isActiveMember() && resource.data.userId == request.auth.uid);
      // You create/edit/remove only your own trips; admins may remove any.
      allow create: if isActiveMember() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin() || (isActiveMember() && resource.data.userId == request.auth.uid);
    }

    match /meta/{doc} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }
  }
}
